# ==========================================
# HashChat - Environment Variables Template
# ==========================================
# Copy this file to .env and fill in your actual values.

# --- SERVER CONFIG ---
PORT=5000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=your_long_random_jwt_secret_here
MONGO_URI=mongodb://localhost:27017/anonchat

# --- EMAIL SERVICE (Resend.com) ---
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- CLOUDINARY (Media Storage) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- MAINTENANCE & EXPIRY ---
# Clean up images after X days
MEDIA_EXPIRY_DAYS=7
# Clean up guest accounts after X days
GUEST_PURGE_DAYS=30

# --- SECURITY & REGEX ---
# Username: Alpha-numeric, dots, and underscores
AUTH_USERNAME_REGEX=^[a-zA-Z0-9._]+$
# Room name: Alpha-numeric, dots, and underscores
AUTH_ROOMNAME_REGEX=^[a-zA-Z0-9._]+$
# Password: 8+ chars, Uppercase, Lowercase, Number, Special char
AUTH_PASSWORD_REGEX=^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[_@$!%*?&.])[A-Za-z\d@$!%*?&._]{8,}$

# --- RATE LIMITING (Daily actions) ---
DAILY_LIMIT_GUESTS=3
DAILY_LIMIT_ROOMS=5
DAILY_LIMIT_MEDIA=20
DAILY_LIMIT_AVATAR_CHANGES=5
DAILY_LIMIT_REGISTER=5
DAILY_LIMIT_DM=20
DAILY_LIMIT_JOIN=20

# --- EXPIRY TIMES (Hours/Days) ---
AUTH_EMAIL_EXPIRY_HRS=1
AUTH_PASSWORD_RESET_EXPIRY_HRS=1
AUTH_TOKEN_EXPIRY_DAYS=7

# --- BRUTE FORCE PROTECTION ---
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINS=15
AUTH_MAX_RESET_ATTEMPTS=5
AUTH_RESET_LOCK_MINS=30

# --- ROOM CONFIG ---
MAX_ROOM_MEMBERS=100
