# Rate Limiting
DAILY_LIMIT_GUESTS=3
DAILY_LIMIT_REGISTER=5
DAILY_LIMIT_ROOMS=5
DAILY_LIMIT_MEDIA=50
DAILY_LIMIT_AVATAR_CHANGES=5

# Auth Security
AUTH_MAX_RESET_ATTEMPTS=3
AUTH_RESET_LOCK_MINS=60
AUTH_MAX_VERIFY_RESENDS=3
AUTH_VERIFY_RESEND_LOCK_MINS=30
AUTH_EMAIL_EXPIRY_HRS=24

# Regex Validation (Optional - Defaults are used if not set)
# AUTH_USERNAME_REGEX="^[a-zA-Z]+$"
# AUTH_PASSWORD_REGEX="^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[A-Za-z\\d@$!%*?&]{8,}$"

# Cloudinary (for profile pics and room images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Service (Resend.com)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
